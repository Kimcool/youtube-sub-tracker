{
  "manifest_version": 3,
  "name": "YouTube Sub Tracker",
  "description": "Track recent videos from your YouTube subscriptions",
  "version": "1.0.0",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://www.youtube.com/*", "https://youtube.com/*", "https://lgggg.de/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": ["preset-channels.json"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
